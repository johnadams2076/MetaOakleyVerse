{
  "name": "MetaOakleyVision Dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "forwardPorts": [8787],
  "portsAttributes": {
    "8787": {
      "label": "FastAPI Backend",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-python.python",
        "ms-python.debugpy",
        "sswg.swift-lang"
      ]
    }
  }
}
